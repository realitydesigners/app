---
---

<div class="w-full h-auto flex-wrap flex justify-center bg-slate-100 pt-40">
  <div class="flex w-1/3 h-auto relative justify-center items-center">
    <h1 class="text-xl font-sans text-white absolute flex z-10">Expand</h1>
    <img
      src="https://picsum.photos/id/593/300/300"
      class="w-full h-full"
      alt="a tiger"
    />
  </div>
  <div class="flex w-1/3 h-auto relative justify-center items-center">
    <h1 class="text-xl font-sans text-white absolute flex z-10">Rotate</h1>
    <img
      src="https://picsum.photos/id/593/300/300"
      class="w-full h-full"
      alt="a tiger"
    />
  </div>
  <div class="flex inner w-1/3 h-auto relative justify-center items-center">
    <h1 class="text-xl font-sans text-black absolute flex z-10">Clear</h1>
    <div class="inner w-full h-full bg-white"></div>
  </div>
</div>

<style>
  .inner {
    --s: 16px; /* size of the frame */
    --b: 6px; /* border thickness */
    --w: 250px; /* width of the image */
    --c: #fd1919;
    position: relative;
    width: var(--w);
    aspect-ratio: 1;
    object-fit: cover;
    padding: var(--s);
    --_g: rgba(234, 234, 234, 0) 05%, var(--c) 0;

    outline-offset: calc(var(--w) / -2 - var(--s));
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
    transition: 0.6s;
    cursor: pointer;
  }
  .inner:hover {
    outline-offset: 2px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    --_p: calc(var(--s) / 4);
    transition: 0.6s, background-position 0.3s 0.35s;
  }

  img {
    --s: 16px; /* size of the frame */
    --b: 6px; /* border thickness */
    --w: 250px; /* width of the image */
    --c: #000000;
    position: relative;
    width: var(--w);
    aspect-ratio: 1;
    object-fit: cover;
    padding: var(--s);
    --_g: rgba(234, 234, 234, 0) 25%, var(--c) 0;
    background: conic-gradient(
          from 90deg at top var(--b) left var(--b),
          var(--_g)
        )
        var(--_p, -5%) var(--_p, -5%),
      conic-gradient(from 180deg at top var(--b) right var(--b), var(--_g))
        calc(100% - var(--_p, -5%)) var(--_p, -5%),
      conic-gradient(from 0deg at bottom var(--b) left var(--b), var(--_g))
        var(--_p, -5%) calc(100% - var(--_p, -5%)),
      conic-gradient(from -90deg at bottom var(--b) right var(--b), var(--_g))
        calc(100% - var(--_p, -5%)) calc(100% - var(--_p, -5%));
    background-size: 20% 20%;
    background-repeat: no-repeat;

    outline-offset: calc(var(--w) / -2 - var(--s));
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
    transition: 0.6s;
    cursor: pointer;
  }
  img:hover {
    outline-offset: 2px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    --_p: calc(var(--s) / 4);
    transition: 0.6s, background-position 0.3s 0.35s;
  }
</style>
